@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #FEFEFE
  BorderColor #444444
  BorderThickness 2
}
skinparam package {
  BackgroundColor #F5F8FA
  BorderColor #5B7C99
  BorderThickness 2
}
skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #333333
  BorderThickness 2
}
skinparam note {
  BackgroundColor #FFF9E6
  BorderColor #FFA500
  BorderThickness 2
}

title Use-case диаграмма функционального тестирования tutu.ru

actor "Гость" as Guest

rectangle "tutu.ru" {

  package "Главная страница\nwww.tutu.ru" {
    usecase "Открыть модалку\nавторизации\nи ввести email" as UC10
  }

  package "Ж/д билеты\n/poezda/" {
    usecase "Поиск ж/д\nМосква -> СПб\nс выбором даты" as UC01
    usecase "Фильтр "Сапсан"\nна результатах ж/д" as UC02
    usecase "Переключение даты\nв date-strip\nрезультатов ж/д" as UC03
  }

  package "Авиабилеты\navia.tutu.ru" {
    usecase "Поиск авиабилетов\nМосква -> СПб" as UC04
    usecase "Негативный:\nодинаковые города\nв авиа форме" as UC12
  }

  package "Автобусы\nbus.tutu.ru" {
    usecase "Поиск автобусов\nМосква -> Тула\nна завтра" as UC06
  }

  package "Отели\nhotel.tutu.ru" {
    usecase "Поиск отелей\nв Сочи на 2 ночи" as UC07
  }

  package "Электрички\n/prigorod/" {
    usecase "Расписание\nэлектричек\nМосква -> Мытищи" as UC08
  }

  package "Справочная\n/2read/" {
    usecase "Поиск\nв справочной" as UC11
  }
}

Guest --> UC01
Guest --> UC02
Guest --> UC03
Guest --> UC04
Guest --> UC06
Guest --> UC07
Guest --> UC08
Guest --> UC10
Guest --> UC11
Guest --> UC12

UC02 ..> UC01 : <<extend>>\nпосле UC-01
UC03 ..> UC01 : <<extend>>\nпосле UC-01

note right of UC12
  <b>Негативный сценарий</b>
  Система должна:
  - Не пустить на /f/...
  - Показать валидацию
  - URL остается avia.tutu.ru
end note

note bottom of UC10
  <b>Авторизация</b>
  - Открыть модалку
  - Ввести email
  - Клик "Получить код"
end note

note right of UC08
  <b>Расписание</b>
  - >= 1 время HH:MM
  - /prigorod/ в URL
end note
@enduml